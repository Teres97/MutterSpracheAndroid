<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MutterSprache"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#6200EE" />

        <Button
            android:id="@+id/languageButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lang"
            style="?android:attr/buttonBarButtonStyle"
            android:textColor="#334155"
            android:textSize="13sp" />

        <Button
            android:id="@+id/manageLangsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage"
            style="?android:attr/buttonBarButtonStyle"
            android:textColor="#334155"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_preferences"
            android:contentDescription="Settings"
            android:tint="#475569" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Hero Active Sentence Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="180dp"
                android:orientation="vertical"
                android:background="@drawable/bg_hero_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOW PLAYING"
                    android:textColor="#E9D5FF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/textViewSentences"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="112dp"
                    android:minLines="4"
                    android:gravity="center_vertical"
                    android:text="Press Start to play"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Learning Controls Panel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <!-- Control Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/start_button"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Start"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_button_primary"
                        android:layout_marginRight="6dp"
                        android:textAllCaps="false"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/stop_button"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Stop"
                        android:textColor="#6200EE"
                        android:background="@drawable/bg_button_secondary"
                        android:layout_marginLeft="6dp"
                        android:layout_marginRight="6dp"
                        android:textAllCaps="false"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/repeat_button"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Repeat"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_button_primary"
                        android:layout_marginLeft="6dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:textAllCaps="false"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Speed Control -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speed Speech"
                    android:textSize="14sp"
                    android:textColor="#475569"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <SeekBar
                    android:id="@+id/speedSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="100"
                    android:paddingLeft="0dp"
                    android:paddingRight="0dp" />
            </LinearLayout>

            <!-- Add Sentence Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Sentence"
                    android:textSize="14sp"
                    android:textColor="#475569"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/editText"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Original Text"
                    android:background="@drawable/bg_input"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:textSize="15sp"
                    android:textColor="#1E293B"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/translateText"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Translation"
                    android:background="@drawable/bg_input"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:textSize="15sp"
                    android:textColor="#1E293B"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/addButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Add Sentence"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_primary"
                    android:textAllCaps="false"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Sentences Feed List -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ListView
            android:id="@+id/listView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false" />
    </RelativeLayout>

</LinearLayout>
